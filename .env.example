# NetGuard — Ortam Değişkenleri Şablonu
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun:
#   cp .env.example .env

# ── Güvenlik ──────────────────────────────────────────────────────────
# Rastgele üretin: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=BURAYA_GIZLI_ANAHTAR_YAZIN

# ── InfluxDB ──────────────────────────────────────────────────────────
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=BURAYA_INFLUXDB_TOKEN_YAZIN
INFLUXDB_ORG=netguard
INFLUXDB_BUCKET=metrics
INFLUXDB_ADMIN_PASSWORD=NetGuard2024!

# ── E-posta bildirimleri (opsiyonel) ──────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=

# ── Webhook bildirimleri (opsiyonel) ──────────────────────────────────
WEBHOOK_URL=
WEBHOOK_TYPE=discord

# ── Threat Intelligence ────────────────────────────────────────────────
# https://www.abuseipdb.com/api adresinden ücretsiz API key alın
ABUSEIPDB_API_KEY=

# ── Sunucu adresi (Dashboard + WebSocket için) ────────────────────────
# Tarayıcıdan erişilen IP ya da domain — örnek: 192.168.1.100
NETGUARD_HOST=localhost

# ── Port yapılandırması (opsiyonel) ───────────────────────────────────
SYSLOG_PORT=5140
NETFLOW_PORT=2055
