[
  {
    "rule_id": "ssh_brute_force",
    "name": "SSH Brute Force Saldırısı",
    "description": "Aynı IP'den 300 saniye içinde 5+ başarısız SSH girişi",
    "match_event_type": "ssh_failure",
    "group_by": "src_ip",
    "window_seconds": 300,
    "threshold": 5,
    "severity": "critical",
    "output_event_type": "brute_force_detected",
    "enabled": true
  },
  {
    "rule_id": "port_scan_detected",
    "name": "Port Tarama Girişimi",
    "description": "Aynı IP'den 60 saniye içinde 3+ port tarama olayı",
    "match_event_type": "port_scan_attempt",
    "group_by": "src_ip",
    "window_seconds": 60,
    "threshold": 3,
    "severity": "warning",
    "output_event_type": "port_scan_detected",
    "enabled": true
  },
  {
    "rule_id": "icmp_flood_detected",
    "name": "ICMP Flood Saldırısı",
    "description": "Aynı IP'den 60 saniye içinde 3+ ICMP flood olayı",
    "match_event_type": "icmp_flood_attempt",
    "group_by": "src_ip",
    "window_seconds": 60,
    "threshold": 3,
    "severity": "warning",
    "output_event_type": "icmp_flood_detected",
    "enabled": true
  },
  {
    "rule_id": "arp_attack_detected",
    "name": "ARP Saldırısı Tespit Edildi",
    "description": "Aynı IP'den 120 saniye içinde 2+ ARP spoof girişimi",
    "match_event_type": "arp_spoof_attempt",
    "group_by": "src_ip",
    "window_seconds": 120,
    "threshold": 2,
    "severity": "critical",
    "output_event_type": "arp_attack_detected",
    "enabled": true
  },
  {
    "rule_id": "dns_burst_detected",
    "name": "Anormal DNS Sorgu Patlaması",
    "description": "Aynı hosttan 60 saniye içinde 3+ anormal DNS sorgusu",
    "match_event_type": "dns_query_burst",
    "group_by": "source_host",
    "window_seconds": 60,
    "threshold": 3,
    "severity": "warning",
    "output_event_type": "dns_attack_suspected",
    "enabled": true
  },
  {
    "rule_id": "device_sustained_outage",
    "name": "Cihaz Kesintili Erişilemezlik",
    "description": "Aynı cihaz 120 saniye içinde 2+ kez down olarak raporlandı",
    "match_event_type": "device_down",
    "group_by": "source_host",
    "window_seconds": 120,
    "threshold": 2,
    "severity": "warning",
    "output_event_type": "sustained_outage_detected",
    "enabled": true
  },
  {
    "rule_id": "snmp_trap_burst",
    "name": "SNMP Trap Patlaması",
    "description": "Aynı cihazdan 300 saniye içinde 5+ SNMP trap alındı",
    "match_event_type": "snmp_trap",
    "group_by": "source_host",
    "window_seconds": 300,
    "threshold": 5,
    "severity": "warning",
    "output_event_type": "snmp_trap_burst_detected",
    "enabled": true
  }
]
