[
  {
    "rule_id": "brute_force_ssh",
    "name": "SSH Brute Force",
    "description": "Aynı IP'den kısa sürede çok sayıda başarısız SSH girişi",
    "match_event_type": "ssh_failure",
    "group_by": "src_ip",
    "window_seconds": 300,
    "threshold": 5,
    "severity": "critical",
    "output_event_type": "brute_force_detected",
    "enabled": true
  },
  {
    "rule_id": "port_scan_from_detector",
    "name": "Port Tarama Tespiti",
    "description": "Dedektörden gelen port tarama girişimleri",
    "match_event_type": "port_scan_attempt",
    "group_by": "src_ip",
    "window_seconds": 120,
    "threshold": 3,
    "severity": "warning",
    "output_event_type": "port_scan_detected",
    "enabled": true
  },
  {
    "rule_id": "arp_spoof_from_detector",
    "name": "ARP Spoofing Tespiti",
    "description": "ARP tablosunda IP-MAC eşleme değişikliği — tek tespit bile kritik",
    "match_event_type": "arp_spoof_attempt",
    "group_by": "src_ip",
    "window_seconds": 300,
    "threshold": 1,
    "severity": "critical",
    "output_event_type": "arp_spoof_detected",
    "enabled": true
  },
  {
    "rule_id": "icmp_flood_from_detector",
    "name": "ICMP Flood Tespiti",
    "description": "Yüksek hızda ICMP paketi — DoS saldırısı göstergesi",
    "match_event_type": "icmp_flood_attempt",
    "group_by": "source_host",
    "window_seconds": 60,
    "threshold": 1,
    "severity": "critical",
    "output_event_type": "icmp_flood_detected",
    "enabled": true
  },
  {
    "rule_id": "dns_anomaly_from_detector",
    "name": "DNS Anomali Tespiti",
    "description": "Anormal DNS sorgu yoğunluğu",
    "match_event_type": "dns_query_burst",
    "group_by": "src_ip",
    "window_seconds": 120,
    "threshold": 2,
    "severity": "warning",
    "output_event_type": "dns_anomaly_detected",
    "enabled": true
  },
  {
    "rule_id": "suricata_alert_burst",
    "name": "Suricata Alert Patlaması",
    "description": "Kısa sürede çok sayıda Suricata IDS alarmı",
    "match_event_type": "suricata_alert",
    "group_by": "src_ip",
    "window_seconds": 120,
    "threshold": 10,
    "severity": "critical",
    "output_event_type": "ids_alert_burst",
    "enabled": true
  },
  {
    "rule_id": "wazuh_critical_burst",
    "name": "Wazuh Kritik Alert Patlaması",
    "description": "Aynı host'tan kısa sürede çok sayıda Wazuh kritik alarmı",
    "match_event_type": "wazuh_rule_",
    "match_severity": "critical",
    "group_by": "source_host",
    "window_seconds": 300,
    "threshold": 5,
    "severity": "critical",
    "output_event_type": "wazuh_critical_burst",
    "enabled": true
  }
]
